<mujoco model="robot">
  <compiler angle="radian" meshdir="assets/" texturedir="assets/"/>

  <asset>
    <mesh name="Bottom" content_type="model/stl" file="../meshes/Bottom.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Top" content_type="model/stl" file="../meshes/Top.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Wing1" content_type="model/stl" file="../meshes/Wing1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Wing2" content_type="model/stl" file="../meshes/Wing2.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0.05">
      <freejoint/> 
      <site name="imu_site" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>
      <inertial pos="0 0 0" mass="2.0" diaginertia="0.01 0.01 0.02"/>
      <geom type="mesh" contype="1" conaffinity="1" group="1" density="1000" rgba="0 0 0 1" mesh="Bottom"/>
      <geom pos="-0.027 0 0.1" quat="0 0 0 1" type="mesh" contype="1" conaffinity="1" group="1" density="0" rgba="1 0.3 0.1 1" mesh="Top"/>
      <geom size="0.005 0.015 0.015" pos="0.073 0 0.2" quat="-1 0 0 0" type="box" contype="1" conaffinity="1" group="1" density="0" rgba="0 0 0 1"/>

      <body name="camera" pos="-0.10 0.0 0.15" quat="0 0 0 1">
        <geom type="box" size="0.005 0.015 0.015" rgba="0 0 0 1"/>
        
        <camera name="camera" fovy="58" mode="fixed" pos="0 0 0" quat="0.5 0.5 -0.5 -0.5"/>
      </body>
      <body name="KapiBara_left_ear" pos="0.063 -0.075 0.14" quat="0 -0.707107 0 0.707107">
        <inertial pos="0 0 0" quat="0.5 0.5 -0.5 0.5" mass="0.1" diaginertia="2.88e-05 1.52333e-05 1.52333e-05"/>
        <joint name="KapiBara_left_ear_joint" pos="0 0 0" axis="0 -1 0" range="0 3.14159" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="Wing1"/>
      </body>
      <body name="KapiBara_righ_ear" pos="0.063 0.07 0.14" quat="0 -0.707107 0 0.707107">
        <inertial pos="0 0 0" quat="0.5 0.5 -0.5 0.5" mass="0.1" diaginertia="2.88e-05 1.52333e-05 1.52333e-05"/>
        <joint name="KapiBara_right_ear_joint" pos="0 0 0" axis="0 -1 0" range="0 3.14159" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="1 1 1 1" mesh="Wing2"/>
      </body>

      <body name="KapiBara_left_wheel1" pos="0.065 0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_left1_joint" pos="0 0 0" axis="0 0 1" actuatorfrcrange="-10000 10000"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
      <body name="KapiBara_left_wheel2" pos="0.005 0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_left2_joint" pos="0 0 0" axis="0 0 1" actuatorfrcrange="-10000 10000"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
      <body name="KapiBara_left_wheel3" pos="-0.055 0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_left3_joint" pos="0 0 0" axis="0 0 1" actuatorfrcrange="-10000 10000"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
      <body name="KapiBara_right_wheel1" pos="0.005 -0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_right2_joint" pos="0 0 0" axis="0 0 1"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
      <body name="KapiBara_right_wheel2" pos="0.065 -0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_right1_joint" pos="0 0 0" axis="0 0 1"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
      <body name="KapiBara_right_wheel3" pos="-0.055 -0.066 0.0135" quat="0.707107 -0.707107 0 0">
        <inertial pos="0 0 0" mass="0.1" diaginertia="3.05333e-05 3.05333e-05 2.88e-05"/>
        <joint name="KapiBara_wheel_right3_joint" pos="0 0 0" axis="0 0 1"/>
        <geom size="0.024 0.022" type="cylinder" contype="1" conaffinity="1" group="1" density="0" rgba="1 1 1 1"/>
      </body>
    </body>
  </worldbody>

  <option integrator="implicitfast"/>
  
  <default>
    <default class="visual">
      <geom group="2" type="mesh" contype="0" conaffinity="0"/>
    </default>
    <default class="collision">
      <geom group="3" type="mesh"/>
    </default>
  </default>

  <sensor>
    <accelerometer name="kapibara_imu_accel" site="imu_site" />
    <gyro name="kapibara_imu_gyro" site="imu_site" />
    <framequat name="kapibara_imu_quat" objtype="site" objname="imu_site" />
  </sensor>

  <actuator>
      <velocity name="KapiBara_wheel_left1_joint" joint="KapiBara_wheel_left1_joint" kv="0.1" ctrlrange="-10 10"/>
      <velocity name="KapiBara_wheel_left2_joint" joint="KapiBara_wheel_left2_joint" kv="0.1" ctrlrange="-10 10"/>
      <velocity name="KapiBara_wheel_left3_joint" joint="KapiBara_wheel_left3_joint" kv="0.1" ctrlrange="-10 10"/>
      <velocity name="KapiBara_wheel_right3_joint" joint="KapiBara_wheel_right3_joint" kv="0.1" ctrlrange="-10 10"/>
      <velocity name="KapiBara_wheel_right2_joint" joint="KapiBara_wheel_right2_joint" kv="0.1" ctrlrange="-10 10"/>
      <velocity name="KapiBara_wheel_right1_joint" joint="KapiBara_wheel_right1_joint" kv="0.1" ctrlrange="-10 10"/>
      <position name="KapiBara_left_ear_joint" joint="KapiBara_left_ear_joint" kp="1" ctrlrange="-3.14159 3.14159"/>
      <position name="KapiBara_right_ear_joint" joint="KapiBara_right_ear_joint" kp="1" ctrlrange="-3.14159 3.14159"/>
  </actuator>
</mujoco>